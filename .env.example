# ════════════════════════════════════════════════════════════════
# MK Shopzone — AI Growth Engine  |  Environment Variables
# ════════════════════════════════════════════════════════════════
# 1. Copy this file:   cp .env.example .env
# 2. Fill in the real values below
# 3. NEVER commit .env to git
# ════════════════════════════════════════════════════════════════


# ── AI / OpenAI ──────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
# If not set, system uses rule-based fallback (still functional)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Database (MongoDB Atlas recommended) ─────────────────────────────────────
# If not set, backend runs with in-memory store (data lost on restart)
# Get a free cluster at https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=mkshopzone_ai


# ── WhatsApp / Twilio ────────────────────────────────────────────────────────
# Get from https://www.twilio.com/console
# WhatsApp-enabled numbers: https://www.twilio.com/whatsapp/api
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WhatsApp sender — must start with "whatsapp:+1..."
TWILIO_PHONE_NUMBER=whatsapp:+14155238886


# ── Email / SendGrid (preferred) ─────────────────────────────────────────────
# Get from https://sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=hello@mkshopzone.com
SENDGRID_FROM_NAME=MK Shopzone


# ── Email / SMTP Fallback (if not using SendGrid) ────────────────────────────
# Gmail example: enable "App Passwords" at myaccount.google.com/security
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password


# ── App Config ───────────────────────────────────────────────────────────────
# Your public site URL (used in email links)
SITE_URL=https://mkshopzone.com

# Admin panel secret key (set a long random string)
ADMIN_SECRET_KEY=change-me-to-a-long-random-string-32chars

# CORS origins (comma-separated, use * for development only)
ALLOWED_ORIGINS=https://mkshopzone.com,http://localhost:5173

# ── Scheduler ────────────────────────────────────────────────────────────────
# Daily follow-up time (UTC). 03:30 UTC = 09:00 IST
SCHEDULER_HOUR=3
SCHEDULER_MINUTE=30
