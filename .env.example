# MK Shopzone AI Automation Environment Configuration

# API & Third-party Services
VITE_API_KEY=your_api_key_here
VITE_HUGGING_FACE_API=hf_your_token_here
VITE_OPENAI_API=sk_your_key_here
VITE_STRIPE_KEY=pk_live_your_key_here

# Email Configuration
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password_here
NOTIFICATION_EMAIL=team@mkshopzone.com

# Server Configuration
PORT=3001
NODE_ENV=development

# Database Configuration (if using MongoDB)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/mkshopzone
DB_NAME=mkshopzone

# Webhook Integration
WEBHOOK_URL=https://webhook.site/your_endpoint
ZAPIER_WEBHOOK=https://hooks.zapier.com/hooks/catch/your_id/your_hook

# Analytics & Tracking
GOOGLE_ANALYTICS_ID=UA_your_id
SENTRY_DSN=https://your_sentry_url

# Firebase Configuration (for production)
FIREBASE_API_KEY=your_key
FIREBASE_AUTH_DOMAIN=your_domain
FIREBASE_PROJECT_ID=your_project
FIREBASE_STORAGE_BUCKET=your_bucket
FIREBASE_MESSAGING_SENDER_ID=your_id
FIREBASE_APP_ID=your_app_id

# CRM Integration
ZOHO_CRM_TOKEN=your_token
PIPEDRIVE_API_TOKEN=your_token
HUBSPOT_API_KEY=your_key

# SMS Notifications (Twilio)
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_NUMBER=+1234567890

# UI Configuration
VITE_BRAND_COLOR=#ff8c00
VITE_BRAND_NAME=MK Shopzone

# Feature Flags
ENABLE_CHATBOT=true
ENABLE_TRACKING=true
ENABLE_PERSONALIZATION=true
ENABLE_ANALYTICS_DASHBOARD=true

