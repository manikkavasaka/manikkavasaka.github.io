# ════════════════════════════════════════════════════════════════════════════════
# MK Shopzone — Environment Variables Template
# Copy to .env and fill in your actual values
# ════════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# CRITICAL (Required for basic operation)
# ──────────────────────────────────────────────────────────────────────────────

# MongoDB Connection
# Get from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB=mkshopzone_ai

# ──────────────────────────────────────────────────────────────────────────────
# AI Provider Configuration
# Choose ONE: openai | openrouter | ollama
# ──────────────────────────────────────────────────────────────────────────────

# AI Provider selection
PREFERRED_AI_PROVIDER=openai

# OpenAI Configuration (if PREFERRED_AI_PROVIDER=openai)
# Get API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter Configuration (if PREFERRED_AI_PROVIDER=openrouter)
# Get API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=anthropic/claude-3.5-sonnet

# Ollama Configuration (if PREFERRED_AI_PROVIDER=ollama)
# Local LLM server (e.g., running on your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama

# ──────────────────────────────────────────────────────────────────────────────
# WhatsApp / Meta Business API Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Option A: Using Twilio for WhatsApp
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=auth_token_here
TWILIO_WHATSAPP_NUMBER=+1234567890

# Option B: Using Meta Business API directly
# Get credentials from: https://developers.facebook.com/
META_PHONE_NUMBER_ID=102xxxxxxxxxxxxxxx
META_BUSINESS_ACCOUNT_ID=102xxxxxxxxxxxxxxx
META_ACCESS_TOKEN=EAAB...

# ──────────────────────────────────────────────────────────────────────────────
# Email Service Configuration
# Choose ONE: SendGrid | SMTP (Gmail, Office365, etc.)
# ──────────────────────────────────────────────────────────────────────────────

# Option A: SendGrid (Recommended for production)
# Get API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@mkshopzone.com
SENDGRID_FROM_NAME=MK Shopzone

# Option B: SMTP (Gmail, Office365, etc.)
# For Gmail: Use App Password (not your regular password)
# See: https://support.google.com/accounts/answer/185833
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ──────────────────────────────────────────────────────────────────────────────
# Logging & Monitoring
# ──────────────────────────────────────────────────────────────────────────────

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log directory (will be created if doesn't exist)
LOG_DIR=logs

# ──────────────────────────────────────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────────────────────────────────────

# Admin secret key for authentication (change in production!)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET_KEY=your-secure-secret-key-here-change-in-production

# CORS Origins (comma-separated list of allowed frontend origins)
# Examples: http://localhost:5173,https://example.com,https://app.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ──────────────────────────────────────────────────────────────────────────────
# Scheduler Configuration
# Background job timing (24-hour format, in your timezone)
# ──────────────────────────────────────────────────────────────────────────────

# Hour for daily follow-up job (0-23)
SCHEDULER_HOUR=9

# Minute for daily follow-up job (0-59)
SCHEDULER_MINUTE=0

# ──────────────────────────────────────────────────────────────────────────────
# Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Environment: development | production
# Use 'development' for local work, 'production' for deployed app
ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# API Configuration
# ──────────────────────────────────────────────────────────────────────────────

# API title and version (for OpenAPI docs)
API_TITLE=MK Shopzone — AI Growth Engine
API_VERSION=4.0.0

# Enable/disable credentials in CORS
CORS_CREDENTIALS=true

# ════════════════════════════════════════════════════════════════════════════════
# IMPORTANT SECURITY NOTES
# ════════════════════════════════════════════════════════════════════════════════
#
# 1. NEVER commit .env to git — it contains sensitive keys
#    - Add ".env" to .gitignore (already done)
#    - Add ".env.local" to .gitignore (for personal overrides)
#
# 2. NEVER use the same secret in development and production
#    - Generate new ADMIN_SECRET_KEY for each environment
#    - Use strong, random values
#
# 3. Keep API keys secure
#    - Rotate keys periodically
#    - Use least-privilege keys when possible
#    - Remove unused keys immediately
#
# 4. Production deployment
#    - Set ENV=production
#    - Use a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
#    - Enable HTTPS only (app will reject insecure origins)
#    - Use environment-specific values for all keys
#
# 5. Testing
#    - Create .env.test for test environment (never use production keys)
#    - Use mock/dummy values when running tests locally
#    - Rotate API keys if exposed in tests/logs
# ════════════════════════════════════════════════════════════════════════════════
